<style>
.coupon-badge-active {
    background-color: #28a745;
    color: #fff;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
}

.coupon-badge-inactive {
    background-color: #6c757d;
    color: #fff;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
}

.form-section {
    background: #f8f9fa;
    padding: 15px;
    border-radius: 4px;
    margin-bottom: 20px;
}

.coupon-drawer {
    position: fixed;
    top: 0;
    right: -750px;
    width: 750px;
    height: 100vh;
    background: #fff;
    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.15);
    padding: 25px;
    overflow-y: auto;
    transition: right 0.3s ease;
    z-index: 1055;
}

.coupon-drawer.open {
    right: 0;
}

#couponDrawerOverlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    display: none;
    z-index: 1050;
}
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Manage Coupons</h3>
    <a href="#" class="btn btn-primary" onclick="openCouponDrawer(); return false;">+ Add Coupon</a>
</div>

{{#hascoupons}}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Applies To</th>
                    <th>Discount</th>
                    <th>Usage</th>
                    <th>Status</th>
                    <th>Expiry Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {{#coupons}}
                <tr>
                    <td><strong>{{code}}</strong></td>
                    <td>{{target}}</td>
                    <td>{{discount}}</td>
                    <td>{{usage}}</td>
                    <td>
                        {{#isstatus_active}}
                        <span class="coupon-badge-active">{{status}}</span>
                        {{/isstatus_active}}
                        {{^isstatus_active}}
                        <span class="coupon-badge-inactive">{{status}}</span>
                        {{/isstatus_active}}
                    </td>
                    <td>{{expirydate}}</td>
                    <td>
                        <a href="{{editurl}}" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                        <a href="{{deleteurl}}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this coupon?')">Delete</a>
                    </td>
                </tr>
                {{/coupons}}
            </tbody>
        </table>
    </div>
</div>
{{/hascoupons}}

{{#haspagination}}
<div class="card border-0 shadow-sm mt-3">
    <div class="card-body py-3">
        <nav aria-label="Coupons pagination">
            <ul class="pagination justify-content-center mb-0 flex-wrap">
                {{#pageitems}}
                    {{#isnav}}
                        <li class="page-item {{#disabled}}disabled{{/disabled}}">
                            {{#url}}
                                <a class="page-link" href="{{url}}">{{label}}</a>
                            {{/url}}
                            {{^url}}
                                <span class="page-link">{{label}}</span>
                            {{/url}}
                        </li>
                    {{/isnav}}
                    {{#ispage}}
                        <li class="page-item {{#active}}active{{/active}}" {{#active}}aria-current="page"{{/active}}>
                            {{#active}}
                                <span class="page-link">{{label}}</span>
                            {{/active}}
                            {{^active}}
                                <a class="page-link" href="{{url}}">{{label}}</a>
                            {{/active}}
                        </li>
                    {{/ispage}}
                    {{#isellipsis}}
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    {{/isellipsis}}
                {{/pageitems}}
            </ul>
        </nav>
    </div>
</div>
{{/haspagination}}

{{^hascoupons}}
<div class="alert alert-info">
    No coupons yet. <a href="#" onclick="openCouponDrawer(); return false;">Create your first coupon</a>
</div>
{{/hascoupons}}

<div id="couponDrawerOverlay"></div>

<div class="coupon-drawer" id="couponDrawer" style="display:none;">
    <div style="position: relative;">
        <button type="button" onclick="closeCouponDrawer();" style="position: absolute; top: -10px; right: -10px; background: none; border: none; font-size: 24px; cursor: pointer;">x</button>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">{{#editingcoupon.id}}Edit{{/editingcoupon.id}}{{^editingcoupon.id}}Create{{/editingcoupon.id}} Coupon</h5>
            </div>
            <div class="card-body">

                {{#haserrors}}
                <div class="alert alert-danger">
                    <ul class="mb-0">
                        {{#errors}}
                        <li>{{.}}</li>
                        {{/errors}}
                    </ul>
                </div>
                {{/haserrors}}

                <form method="post" action="{{formurl}}" class="row g-3">
                    <div class="col-md-6 form-section">
                        <label class="form-label"><strong>Coupon Code</strong></label>
                        <input type="text" name="code" class="form-control" value="{{editingcoupon.code}}" placeholder="e.g., SUMMER20" required>
                        <small class="text-muted">Must be unique. Will be converted to uppercase.</small>
                    </div>

                    <div class="col-md-6 form-section">
                        <label class="form-label"><strong>Discount Percentage (%)</strong></label>
                        <input type="number" name="discountpercent" class="form-control" value="{{editingcoupon.discountpercent}}" step="0.01" min="0" max="100" required>
                    </div>

                    <div class="col-md-6 form-section">
                        <label class="form-label"><strong>Usage Limit (Optional)</strong></label>
                        <input type="number" name="maxuse" class="form-control" value="{{editingcoupon.maxuse}}" min="0" step="1" placeholder="e.g., 5">
                        <small class="text-muted">Leave empty or 0 for unlimited uses.</small>
                    </div>

                    <div class="col-md-6 form-section">
                        <label class="form-label"><strong>Expiry Date (Optional)</strong></label>
                        <input type="date" name="expirydate" class="form-control" value="{{editingcoupon.expirydate}}">
                    </div>

                    <div class="col-md-6 form-section">
                        <label class="form-label"><strong>Status</strong></label>
                        <select name="status" class="form-select" required>
                            <option value="active" {{#editingcoupon.isstatusactive}}selected{{/editingcoupon.isstatusactive}}>Active</option>
                            <option value="inactive" {{#editingcoupon.isstatusinactive}}selected{{/editingcoupon.isstatusinactive}}>Inactive</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <button type="submit" class="btn btn-success">Save Coupon</button>
                        <button type="button" onclick="closeCouponDrawer();" class="btn btn-outline-secondary">Cancel</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
function clearCouponDrawerQueryParams() {
    const url = new URL(window.location.href);
    url.searchParams.delete('action');
    url.searchParams.delete('id');
    window.history.replaceState({}, '', url);
}

function closeCouponDrawer() {
    const overlay = document.getElementById('couponDrawerOverlay');
    const drawer = document.getElementById('couponDrawer');
    if (drawer) {
        drawer.classList.remove('open');
        drawer.style.display = 'none';
    }
    if (overlay) {
        overlay.style.display = 'none';
    }
    clearCouponDrawerQueryParams();
}

function openCouponDrawer() {
    const overlay = document.getElementById('couponDrawerOverlay');
    const drawer = document.getElementById('couponDrawer');
    if (overlay) {
        overlay.style.display = 'block';
    }
    if (drawer) {
        drawer.style.display = 'block';
        void drawer.offsetWidth;
        drawer.classList.add('open');
    }
}

document.getElementById('couponDrawerOverlay')?.addEventListener('click', closeCouponDrawer);
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeCouponDrawer();
    }
});

{{#showcoupondrawer}}
openCouponDrawer();
{{/showcoupondrawer}}
</script>
