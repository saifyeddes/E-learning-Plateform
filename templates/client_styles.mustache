}

.es-chatbot-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 0.8rem;
    border-bottom: 1px solid var(--es-line);
    background: linear-gradient(135deg, rgba(15, 108, 191, 0.08), rgba(15, 108, 191, 0.02));
}

.es-chatbot-close {
    border: 0;
    background: transparent;
    color: #475467;
    font-size: 1.35rem;
    line-height: 1;
}

.es-chatbot-messages {
    flex: 1;
    overflow: auto;
    padding: 0.72rem;
    background: #f8fafc;
}

.es-chatbot-msg {
    max-width: 88%;
    margin-bottom: 0.5rem;
    padding: 0.48rem 0.62rem;
    border-radius: 10px;
    font-size: 0.9rem;
    line-height: 1.35;
}

.es-chatbot-msg-bot {
    background: #ffffff;
    border: 1px solid #d7e4f5;
    color: #102a43;
}

.es-chatbot-msg-user {
    margin-left: auto;
    background: #0f6cbf;
    color: #fff;
}

.es-chatbot-meta {
    max-width: 88%;
    margin-bottom: 0.6rem;
}

.es-chatbot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
}

.es-chatbot-suggestion-btn {
    border: 1px solid #bfd7f3;
    background: #eef5fd;
    color: #0d4f8b;
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    font-size: 0.78rem;
    line-height: 1.2;
}

.es-chatbot-rating {
    margin-top: 0.45rem;
    display: flex;
    align-items: center;
    gap: 0.28rem;
}

.es-chatbot-rating-label {
    font-size: 0.76rem;
    color: #475467;
    margin-right: 0.2rem;
}

.es-chatbot-rating-star {
    border: 0;
    background: transparent;
    color: #d0d5dd;
    font-size: 1rem;
