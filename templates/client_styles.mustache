</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (window.localElearningSystemChatbotInit) {
        return;
    }
    window.localElearningSystemChatbotInit = true;

    const body = document.body;
    if (!body) {
        return;
    }

    const chatbotFab = document.createElement('button');
    chatbotFab.type = 'button';
    chatbotFab.id = 'esChatbotFab';
    chatbotFab.className = 'es-chatbot-fab';
    chatbotFab.setAttribute('aria-label', 'Open chatbot');
    chatbotFab.setAttribute('title', 'Chatbot');
    chatbotFab.innerHTML = '<i class="fa fa-comments"></i>';

    const chatbotPanel = document.createElement('div');
    chatbotPanel.id = 'esChatbotPanel';
    chatbotPanel.className = 'es-chatbot-panel d-none';
    chatbotPanel.setAttribute('role', 'dialog');
    chatbotPanel.setAttribute('aria-modal', 'false');
    chatbotPanel.setAttribute('aria-label', 'Course assistant');
    chatbotPanel.innerHTML = '' +
        '<div class="es-chatbot-head">' +
            '<strong>Assistant IA</strong>' +
            '<button type="button" id="esChatbotClose" class="es-chatbot-close" aria-label="Close chatbot">&times;</button>' +
        '</div>' +
        '<div id="esChatbotMessages" class="es-chatbot-messages">' +
            '<div class="es-chatbot-msg es-chatbot-msg-bot">Exemples: prix phys, achete math 5 mois, buy science 2, voir mes cours, checkout.</div>' +
        '</div>' +
        '<form id="esChatbotForm" class="es-chatbot-form">' +
            '<input id="esChatbotInput" type="text" class="form-control" placeholder="Ecrivez votre demande..." autocomplete="off">' +
            '<button type="submit" class="btn btn-primary">Envoyer</button>' +
        '</form>';

    body.appendChild(chatbotFab);
    body.appendChild(chatbotPanel);

    const chatbotClose = document.getElementById('esChatbotClose');
    const chatbotForm = document.getElementById('esChatbotForm');
    const chatbotInput = document.getElementById('esChatbotInput');
    const chatbotMessages = document.getElementById('esChatbotMessages');

    const appendChatMessage = function(text, isBot) {
        if (!chatbotMessages) {
            return;
        }
        const el = document.createElement('div');
        el.className = 'es-chatbot-msg ' + (isBot ? 'es-chatbot-msg-bot' : 'es-chatbot-msg-user');
        el.textContent = text;
        chatbotMessages.appendChild(el);
        chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
    };

    const appendChatMeta = function() {
        if (!chatbotMessages) {
            return null;
        }

        const meta = document.createElement('div');
        meta.className = 'es-chatbot-meta';
        chatbotMessages.appendChild(meta);
        chatbotMessages.scrollTop = chatbotMessages.scrollHeight;
        return meta;
    };

    const renderSuggestions = function(metaContainer, suggestions) {
        if (!metaContainer || !Array.isArray(suggestions) || !suggestions.length) {
            return;
        }

        const wrapper = document.createElement('div');
        wrapper.className = 'es-chatbot-suggestions';

        suggestions.slice(0, 3).forEach(function(suggestion) {
            if (!suggestion || typeof suggestion !== 'string') {
                return;
            }

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'es-chatbot-suggestion-btn';
            btn.textContent = suggestion;
            btn.addEventListener('click', function() {
                chatbotInput.value = suggestion;
                sendQuestion(suggestion);
            });
            wrapper.appendChild(btn);
        });

        if (wrapper.childNodes.length > 0) {
            metaContainer.appendChild(wrapper);
        }
    };

    const renderRating = function(metaContainer) {
        if (!metaContainer) {
            return;
        }

        const rating = document.createElement('div');
        rating.className = 'es-chatbot-rating';

        const label = document.createElement('span');
        label.className = 'es-chatbot-rating-label';
        label.textContent = 'Votre avis';
        rating.appendChild(label);

        const stars = [];
        for (let i = 1; i <= 5; i++) {
            const star = document.createElement('button');
            star.type = 'button';
            star.className = 'es-chatbot-rating-star';
            star.textContent = '★';
            star.setAttribute('aria-label', i + ' etoiles');
            star.addEventListener('click', function() {
                stars.forEach(function(s, idx) {
                    s.classList.toggle('active', idx < i);
                });
                appendChatMessage('Merci pour votre avis: ' + i + '/5.', true);
            });
            stars.push(star);
            rating.appendChild(star);
        }

        metaContainer.appendChild(rating);
    };

    const sendQuestion = function(question) {
        if (!question) {
            return;
        }

        appendChatMessage(question, false);
        chatbotInput.value = '';

        const wwwroot = (window.M && M.cfg && M.cfg.wwwroot) ? M.cfg.wwwroot : '';
        const sesskey = (window.M && M.cfg && M.cfg.sesskey) ? M.cfg.sesskey : '';
        const endpoint = wwwroot + '/local/elearning_system/chatbot.php';

        if (!endpoint || !sesskey) {
            appendChatMessage('Session invalide. Rechargez la page puis reessayez.', true);
            return;
        }

        fetch(endpoint, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: new URLSearchParams({
                sesskey: sesskey,
                message: question
            }).toString()
        })
        .then(function(res) {
            return res.json();
        })
        .then(function(data) {
            const reply = (data && data.reply) ? data.reply : 'Je n ai pas compris. Essayez avec un nom de cours.';
            appendChatMessage(reply, true);

            const meta = appendChatMeta();
            renderSuggestions(meta, data && data.suggestions ? data.suggestions : []);
            if (!data || data.showrating !== false) {
                renderRating(meta);
            }

            if (data && data.redirecturl) {
                setTimeout(function() {
                    window.location.href = data.redirecturl;
                }, 900);
            }
        })
        .catch(function() {
            appendChatMessage('Erreur reseau. Reessayez.', true);
        });
    };

    chatbotFab.addEventListener('click', function() {
        chatbotPanel.classList.toggle('d-none');
        if (!chatbotPanel.classList.contains('d-none') && chatbotInput) {
            chatbotInput.focus();
        }
    });

    if (chatbotClose) {
        chatbotClose.addEventListener('click', function() {
            chatbotPanel.classList.add('d-none');
        });
    }

    if (!chatbotForm || !chatbotInput) {
        return;
    }

    chatbotForm.addEventListener('submit', function(e) {
        e.preventDefault();
        const question = chatbotInput.value.trim();
        sendQuestion(question);
    });
});
</script>
