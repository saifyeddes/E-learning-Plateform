<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="mb-0">Your Cart</h3>
            <a href="{{storeurl}}" class="btn btn-outline-secondary btn-sm">Continue Shopping</a>
        </div>
    </div>

    {{#hasproducts}}
    <div class="card mb-3">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Qty</th>
                        <th>Price</th>
                        <th>Line Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    {{#products}}
                    <tr>
                        <td><a href="{{producturl}}">{{name}}</a></td>
                        <td>
                            <div class="d-inline-flex align-items-center gap-1">
                                <a href="{{decreaseurl}}" class="btn btn-sm btn-outline-secondary" aria-label="Decrease">-</a>
                                <span class="px-2">{{qty}}</span>
                                <a href="{{increaseurl}}" class="btn btn-sm btn-outline-secondary" aria-label="Increase">+</a>
                            </div>
                        </td>
                        <td>${{price}}</td>
                        <td>${{lineprice}}</td>
                        <td><a href="{{removeurl}}" class="btn btn-sm btn-outline-danger">Remove</a></td>
                    </tr>
                    {{/products}}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <strong>Total:</strong> ${{total}}
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a href="{{clearcarturl}}" class="btn btn-outline-danger">Clear Cart</a>
                <a href="{{checkouturl}}" class="btn btn-primary">Proceed to Checkout</a>
            </div>
        </div>
    </div>
    {{/hasproducts}}

    {{^hasproducts}}
    <div class="alert alert-info">
        Your cart is empty.
    </div>
    {{/hasproducts}}
</div>
