<style>
.elearn-admin-shell {
    --sidebar-open-width: 280px;
    --sidebar-closed-width: 86px;
    --brand-1: #0f6cbf;
    --brand-2: #1d9a8a;
    --bg-soft: #edf3f9;
    --surface: #ffffff;
    --text-main: #12304f;
    --text-muted: #6c7f95;
    --line: #d5e0ec;
    --shadow: 0 18px 45px rgba(12, 43, 79, 0.12);
    font-family: "Poppins", "Segoe UI", sans-serif;
    min-height: 100%;
    background:
        radial-gradient(circle at 12% 8%, rgba(15, 108, 191, 0.18), transparent 35%),
        radial-gradient(circle at 87% 3%, rgba(29, 154, 138, 0.16), transparent 40%),
        var(--bg-soft);
    color: var(--text-main);
    display: grid;
    grid-template-columns: var(--sidebar-open-width) minmax(0, 1fr);
    gap: 1rem;
    padding: 1rem;
    border-radius: 1rem;
}

.elearn-sidebar {
    position: sticky;
    top: 1rem;
    width: 100%;
    max-height: calc(100vh - 2rem);
    background: linear-gradient(180deg, #ffffff 0%, #f6fbff 100%);
    border-right: 1px solid var(--line);
    box-shadow: var(--shadow);
    z-index: 20;
    transition: width 0.28s ease, transform 0.28s ease;
    overflow: hidden;
}

.elearn-sidebar__inner {
    height: 100%;
    padding: 1rem 0.7rem 1rem;
    overflow-y: auto;
}

.elearn-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.7rem 1rem;
}

.elearn-brand__dot {
    width: 34px;
    height: 34px;
    border-radius: 0.8rem;
    background: linear-gradient(135deg, var(--brand-1), var(--brand-2));
    box-shadow: 0 8px 18px rgba(15, 108, 191, 0.35);
}

.elearn-brand__title {
    font-weight: 600;
    color: var(--text-main);
    white-space: nowrap;
}

.elearn-nav {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
}

.elearn-nav__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border-radius: 0.8rem;
    color: var(--text-main);
    text-decoration: none;
    padding: 0.72rem 0.85rem;
    transition: background-color 0.2s ease, transform 0.2s ease, color 0.2s ease;
}

.elearn-nav__item:hover {
    background: #e8f1fa;
    color: #0f4f8e;
    transform: translateX(2px);
}

.elearn-nav__item.is-active {
    background: linear-gradient(135deg, var(--brand-1), #1b7bcf);
    color: #fff;
    box-shadow: 0 10px 24px rgba(15, 108, 191, 0.28);
}

.elearn-nav__icon {
    width: 28px;
    height: 28px;
    min-width: 28px;
    border-radius: 0.55rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 600;
    background: rgba(18, 48, 79, 0.08);
}

.elearn-nav__icon i {
    font-size: 0.9rem;
}

.elearn-nav__item.is-active .elearn-nav__icon {
    background: rgba(255, 255, 255, 0.26);
}

.elearn-nav__label {
    white-space: nowrap;
    font-weight: 500;
}

.elearn-main {
    flex: 1;
    margin-left: 0;
    padding: 0.25rem 0.25rem 0.5rem;
    transition: none;
    min-width: 0;
}

.elearn-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding: 0.6rem 0.25rem;
}

.elearn-toggle {
    border: 0;
    background: linear-gradient(135deg, var(--brand-1), var(--brand-2));
    color: #fff;
    border-radius: 999px;
    padding: 0.55rem 0.9rem;
    font-weight: 600;
    box-shadow: 0 8px 22px rgba(15, 108, 191, 0.28);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.elearn-toggle:hover {
    transform: translateY(-1px);
    box-shadow: 0 12px 24px rgba(15, 108, 191, 0.34);
}

.elearn-main .card,
.elearn-main .alert,
.elearn-main .generalbox {
    border-radius: 1rem;
    border: 1px solid var(--line);
    box-shadow: 0 10px 25px rgba(12, 43, 79, 0.08);
}

.elearn-main .table {
    border-color: var(--line);
}

.elearn-main .table thead th {
    background: #edf4fb;
    border-bottom: 1px solid var(--line);
}

.elearn-main .form-control,
.elearn-main .form-select {
    border-radius: 0.75rem;
    border-color: #c6d4e4;
}

.elearn-main .btn {
    border-radius: 0.75rem;
}

.elearn-reveal {
    animation: elearnFadeIn 0.45s ease;
}

.elearn-sidebar-overlay {
    position: fixed;
    inset: 0;
    background: rgba(10, 25, 45, 0.34);
    backdrop-filter: blur(2px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s ease, visibility 0.2s ease;
    z-index: 1035;
}

.elearn-admin-shell.is-mobile-open .elearn-sidebar-overlay {
    opacity: 1;
    visibility: visible;
}

.elearn-admin-shell.is-collapsed .elearn-sidebar {
    width: 100%;
}

.elearn-admin-shell.is-collapsed .elearn-main {
    margin-left: 0;
}

.elearn-admin-shell.is-collapsed {
    grid-template-columns: var(--sidebar-closed-width) minmax(0, 1fr);
}

.elearn-admin-shell.is-collapsed .elearn-brand__title,
.elearn-admin-shell.is-collapsed .elearn-nav__label {
    display: none;
}

.elearn-admin-shell.is-collapsed .elearn-brand {
    justify-content: center;
}

.elearn-admin-shell.is-collapsed .elearn-nav__item {
    justify-content: center;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
}

.elearn-admin-shell.is-collapsed .elearn-nav__icon {
    margin: 0;
}

.elearn-admin-shell.is-collapsed .elearn-sidebar__inner {
    padding-left: 0.35rem;
    padding-right: 0.35rem;
}

.elearn-admin-shell.is-collapsed.is-hover-open {
    grid-template-columns: var(--sidebar-open-width) minmax(0, 1fr);
}

.elearn-admin-shell.is-collapsed.is-hover-open .elearn-brand__title,
.elearn-admin-shell.is-collapsed.is-hover-open .elearn-nav__label {
    display: inline;
}

.elearn-admin-shell.is-collapsed.is-hover-open .elearn-brand {
    justify-content: flex-start;
}

.elearn-admin-shell.is-collapsed.is-hover-open .elearn-nav__item {
    justify-content: flex-start;
    padding-left: 0.85rem;
    padding-right: 0.85rem;
}

.product-drawer {
    position: fixed;
    top: 0;
    right: -750px;
    width: 750px;
    height: 100vh;
    background: #fff;
    box-shadow: -4px 0 20px rgba(0,0,0,0.15);
    padding: 25px;
    overflow-y: auto;
    transition: right 0.3s ease;
    z-index: 1055;
}

.ea-chatbot-fab {
    position: fixed;
    right: 22px;
    bottom: 22px;
    width: 56px;
    height: 56px;
    border: 0;
    border-radius: 999px;
    background: #0f6cbf;
    color: #fff;
    box-shadow: 0 10px 24px rgba(15, 108, 191, 0.35);
    z-index: 2000;
}

.ea-chatbot-fab:hover,
.ea-chatbot-fab:focus {
    background: #0d5aa0;
}

.ea-chatbot-panel {
    position: fixed;
    right: 22px;
    bottom: 88px;
    width: min(420px, calc(100vw - 20px));
    height: 500px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: #fff;
    box-shadow: 0 16px 36px rgba(25, 35, 45, 0.22);
    z-index: 2001;
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.ea-chatbot-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.65rem 0.8rem;
    border-bottom: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(15, 108, 191, 0.08), rgba(15, 108, 191, 0.02));
}

.ea-chatbot-close {
    border: 0;
    background: transparent;
    color: #475467;
    font-size: 1.35rem;
    line-height: 1;
}

.ea-chatbot-messages {
    flex: 1;
    overflow: auto;
    padding: 0.72rem;
    background: #f8fafc;
}

.ea-chatbot-msg {
    max-width: 90%;
    margin-bottom: 0.5rem;
    padding: 0.48rem 0.62rem;
    border-radius: 10px;
    font-size: 0.9rem;
    line-height: 1.35;
}

.ea-chatbot-msg-bot {
    background: #ffffff;
    border: 1px solid #d7e4f5;
    color: #102a43;
}

.ea-chatbot-msg-user {
    margin-left: auto;
    background: #0f6cbf;
    color: #fff;
}

.ea-chatbot-meta {
    max-width: 90%;
    margin-bottom: 0.6rem;
}

.ea-chatbot-suggestions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
}

.ea-chatbot-suggestion-btn {
    border: 1px solid #bfd7f3;
    background: #eef5fd;
    color: #0d4f8b;
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    font-size: 0.78rem;
    line-height: 1.2;
}

.ea-chatbot-invoice {
    margin-top: 0.45rem;
}

.ea-chatbot-form {
    display: flex;
    gap: 0.45rem;
    padding: 0.6rem;
    border-top: 1px solid var(--line);
    background: #fff;
}

.ea-chatbot-form .form-control {
    min-height: 40px;
}

.product-drawer.open {
    right: 0;
}

#drawerOverlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    display: none;
    z-index: 1050;
}

.elearn-delete-toast {
    position: fixed;
    top: 50%;
    left: 50%;
    width: min(560px, calc(100vw - 28px));
    background: #fff;
    border: 1px solid #c8d9ec;
    border-radius: 18px;
    box-shadow: 0 24px 60px rgba(16, 42, 67, 0.32);
    z-index: 2100;
    transform: translate(-50%, -46%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.22s ease, transform 0.22s ease;
}

.elearn-delete-toast.is-open {
    opacity: 1;
    transform: translate(-50%, -50%);
    pointer-events: auto;
}

.elearn-delete-toast__content {
    padding: 24px 24px 20px;
}

.elearn-delete-toast__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.45rem;
}

.elearn-delete-toast__title {
    font-weight: 700;
    font-size: 1.1rem;
    color: #102a43;
}

.elearn-delete-toast__close {
    border: 0;
    background: transparent;
    color: #526d8c;
    font-size: 1.25rem;
    line-height: 1;
    padding: 0;
}

.elearn-delete-toast__message {
    margin: 0 0 1.1rem;
    font-size: 1rem;
    color: #243b53;
}

.elearn-delete-toast__actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.55rem;
}

@media (max-width: 575.98px) {
    .elearn-delete-toast__content {
        padding: 18px 16px 16px;
    }
}

@media (max-width: 991.98px) {
    .elearn-admin-shell {
        display: block;
        padding: 0.75rem;
    }

    .elearn-sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        transform: translateX(-100%);
        width: min(84vw, 280px);
        max-height: 100vh;
        z-index: 1040;
    }

    .elearn-main,
    .elearn-admin-shell.is-collapsed .elearn-main {
        margin-left: 0;
    }

    .elearn-admin-shell.is-mobile-open .elearn-sidebar {
        transform: translateX(0);
    }

    .elearn-main {
        padding: 0.25rem;
    }

    .ea-chatbot-fab {
        right: 12px;
        bottom: 12px;
        width: 52px;
        height: 52px;
    }

    .ea-chatbot-panel {
        right: 8px;
        left: 8px;
        width: auto;
        bottom: 70px;
        height: 62vh;
    }
}

@keyframes elearnFadeIn {
    0% {
        opacity: 0;
        transform: translateY(10px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
    }
}
</style>

<div class="elearn-admin-shell" id="elearnAdminShell">
    <aside class="elearn-sidebar" id="elearnSidebar" aria-label="Admin sidebar">
        <div class="elearn-sidebar__inner">
            <div class="elearn-brand">
                <span class="elearn-brand__dot"></span>
                <span class="elearn-brand__title">SIT Admin</span>
            </div>

            <nav class="elearn-nav">
                <a href="{{dashboardurl}}" class="elearn-nav__item {{#isdashboard}}is-active{{/isdashboard}}">
                    <span class="elearn-nav__icon"><i class="fa fa-home"></i></span>
                    <span class="elearn-nav__label">Dashboard</span>
                </a>
                <a href="{{productsurl}}" class="elearn-nav__item {{#isproducts}}is-active{{/isproducts}}">
                    <span class="elearn-nav__icon"><i class="fa fa-cube"></i></span>
                    <span class="elearn-nav__label">Products</span>
                </a>
                <a href="{{ordersurl}}" class="elearn-nav__item {{#isorders}}is-active{{/isorders}}">
                    <span class="elearn-nav__icon"><i class="fa fa-shopping-cart"></i></span>
                    <span class="elearn-nav__label">Orders</span>
                </a>
                <a href="{{parentsurl}}" class="elearn-nav__item {{#isparents}}is-active{{/isparents}}">
                    <span class="elearn-nav__icon"><i class="fa fa-users"></i></span>
                    <span class="elearn-nav__label">Parents</span>
                </a>
                <a href="{{couponsurl}}" class="elearn-nav__item {{#iscoupons}}is-active{{/iscoupons}}">
                    <span class="elearn-nav__icon"><i class="fa fa-tag"></i></span>
                    <span class="elearn-nav__label">Coupons</span>
                </a>
                <a href="{{payementurl}}" class="elearn-nav__item {{#ispayement}}is-active{{/ispayement}}">
                    <span class="elearn-nav__icon"><i class="fa fa-credit-card"></i></span>
                    <span class="elearn-nav__label">Payement</span>
                </a>
                <a href="{{emailtemplatesurl}}" class="elearn-nav__item {{#isemailtemplates}}is-active{{/isemailtemplates}}">
                    <span class="elearn-nav__icon"><i class="fa fa-envelope"></i></span>
                    <span class="elearn-nav__label">Email Templates</span>
                </a>
            </nav>
        </div>
    </aside>

    <div class="elearn-sidebar-overlay" id="elearnSidebarOverlay"></div>

    <main class="elearn-main elearn-reveal">
        <!-- CONTENT -->
        <div>

            {{#isdashboard}}
                {{> local_elearning_system/dashboard_content }}
            {{/isdashboard}}

            {{#isproducts}}
                {{> local_elearning_system/products }}
            {{/isproducts}}

            {{#isorders}}
                <h3>Orders</h3>
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-body">
                        <form method="get" action="{{filterurl}}" class="row g-3 align-items-end">
                            <div class="col-lg-8">
                                <label class="form-label">Search</label>
                                <input type="search" name="search" class="form-control" value="{{searchquery}}" placeholder="Search by customer, email, product, amount or order ID">
                            </div>

                            <div class="col-lg-4">
                                <label class="form-label">Product</label>
                                <select name="productid" class="form-select">
                                    {{#productfilters}}
                                        <option value="{{value}}" {{#selected}}selected{{/selected}}>{{label}}</option>
                                    {{/productfilters}}
                                </select>
                            </div>

                            <div class="col-12 d-flex gap-2">
                                <button type="submit" class="btn btn-primary">Apply filters</button>
                                <a href="{{ordersurl}}" class="btn btn-outline-secondary">Reset</a>
                            </div>
                        </form>
                    </div>
                </div>
                {{#hasorders}}
                <div class="card">
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>User</th>
                                    <th>Email</th>
                                    <th>Product</th>
                                    <th>Durée achetée</th>
                                    <th>Promo</th>
                                    <th>Amount</th>
                                    <th>Date</th>
                                    <th>Facture</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#orders}}
                                <tr>
                                    <td>{{id}}</td>
                                    <td>{{user}}</td>
                                    <td>{{email}}</td>
                                    <td>{{product}}</td>
                                    <td>{{durationachetee}}</td>
                                    <td>{{promo}}</td>
                                    <td>${{amount}}</td>
                                    <td>{{timecreated}}</td>
                                    <td>
                                        <a href="{{invoiceurl}}" class="btn btn-sm btn-outline-primary">Download Facture</a>
                                    </td>
                                </tr>
                                {{/orders}}
                            </tbody>
                        </table>
                    </div>
                </div>

                {{#haspagination}}
                <div class="card border-0 shadow-sm mt-3">
                    <div class="card-body py-3">
                        <nav aria-label="Orders pagination">
                            <ul class="pagination justify-content-center mb-0 flex-wrap">
                                {{#pageitems}}
                                    {{#isnav}}
                                        <li class="page-item {{#disabled}}disabled{{/disabled}}">
                                            {{#url}}
                                                <a class="page-link" href="{{url}}">{{label}}</a>
                                            {{/url}}
                                            {{^url}}
                                                <span class="page-link">{{label}}</span>
                                            {{/url}}
                                        </li>
                                    {{/isnav}}
                                    {{#ispage}}
                                        <li class="page-item {{#active}}active{{/active}}" {{#active}}aria-current="page"{{/active}}>
                                            {{#active}}
                                                <span class="page-link">{{label}}</span>
                                            {{/active}}
                                            {{^active}}
                                                <a class="page-link" href="{{url}}">{{label}}</a>
                                            {{/active}}
                                        </li>
                                    {{/ispage}}
                                    {{#isellipsis}}
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    {{/isellipsis}}
                                {{/pageitems}}
                            </ul>
                        </nav>
                    </div>
                </div>
                {{/haspagination}}
                {{/hasorders}}
                {{^hasorders}}
                <div class="alert alert-info">{{noordersmessage}}</div>
                {{/hasorders}}
            {{/isorders}}

            {{#iscoupons}}
                {{> local_elearning_system/coupons_content }}
            {{/iscoupons}}

            {{#ispayement}}
                {{> local_elearning_system/payement_content }}
            {{/ispayement}}

            {{#isemailtemplates}}
                {{> local_elearning_system/emailtemplates_content }}
            {{/isemailtemplates}}

            {{#isparents}}
                {{> local_elearning_system/parents_content }}
            {{/isparents}}

        </div>
    </main>
</div>

<!-- Drawer Overlay -->
<div id="drawerOverlay" style="
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    display: none;
    z-index: 1050;
"></div>

<!-- Product Drawer -->
<div class="product-drawer" id="productDrawer" style="display:none;">
    {{> local_elearning_system/product_form }}
</div>

<!-- Bundle Drawer -->
<div class="product-drawer" id="bundleDrawer" style="display:none;">
    {{> local_elearning_system/bundle_form }}
</div>

<div class="elearn-delete-toast" id="elearnDeleteToast" role="alertdialog" aria-labelledby="elearnDeleteToastTitle" aria-describedby="elearnDeleteToastMessage" aria-hidden="true">
    <div class="elearn-delete-toast__content">
        <div class="elearn-delete-toast__head">
            <span class="elearn-delete-toast__title" id="elearnDeleteToastTitle">Confirm deletion</span>
            <button type="button" class="elearn-delete-toast__close" id="elearnDeleteToastClose" aria-label="Close">&times;</button>
        </div>
        <p class="elearn-delete-toast__message" id="elearnDeleteToastMessage">Delete this item?</p>
        <div class="elearn-delete-toast__actions">
            <button type="button" class="btn btn-sm btn-outline-secondary" id="elearnDeleteToastCancel">Cancel</button>
            <button type="button" class="btn btn-sm btn-danger" id="elearnDeleteToastConfirm">Delete</button>
        </div>
    </div>
</div>

<script>
function clearDrawerQueryParams() {
    const url = new URL(window.location.href);
    url.searchParams.delete('addnew');
    url.searchParams.delete('edit');
    url.searchParams.delete('addbundle');
    url.searchParams.delete('editbundle');
    window.history.replaceState({}, '', url);
}

function closeDrawer(drawerId) {
    const overlay = document.getElementById('drawerOverlay');
    const productDrawer = document.getElementById('productDrawer');
    const bundleDrawer = document.getElementById('bundleDrawer');

    if (!drawerId || drawerId === 'productDrawer') {
        productDrawer?.classList.remove('open');
        if (productDrawer) {
            productDrawer.style.display = 'none';
        }
    }
    if (!drawerId || drawerId === 'bundleDrawer') {
        bundleDrawer?.classList.remove('open');
        if (bundleDrawer) {
            bundleDrawer.style.display = 'none';
        }
    }

    if (overlay) {
        overlay.style.display = 'none';
    }

    clearDrawerQueryParams();
}

window.closeDrawer = closeDrawer;
window.closeBundleDrawer = function() {
    closeDrawer('bundleDrawer');
};

document.getElementById('drawerOverlay')?.addEventListener('click', function() {
    closeDrawer();
});

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        closeDrawer();
    }
});

function openDrawer(drawerId) {
    const overlay = document.getElementById('drawerOverlay');
    const drawer = document.getElementById(drawerId);
    if (overlay) {
        overlay.style.display = 'block';
    }
    if (drawer) {
        drawer.style.display = 'block';
        // Force reflow before adding class so transition runs consistently.
        void drawer.offsetWidth;
        drawer.classList.add('open');
    }
}

// Handle query params for drawer opening
const params = new URLSearchParams(window.location.search);
if (params.has('addnew') || params.has('edit')) {
    openDrawer('productDrawer');
}
if (params.has('addbundle') || params.has('editbundle')) {
    openDrawer('bundleDrawer');
}
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (window.localElearningDeleteToastInit) {
        return;
    }
    window.localElearningDeleteToastInit = true;

    const toast = document.getElementById('elearnDeleteToast');
    const messageNode = document.getElementById('elearnDeleteToastMessage');
    const confirmBtn = document.getElementById('elearnDeleteToastConfirm');
    const cancelBtn = document.getElementById('elearnDeleteToastCancel');
    const closeBtn = document.getElementById('elearnDeleteToastClose');

    if (!toast || !messageNode || !confirmBtn || !cancelBtn || !closeBtn) {
        return;
    }

    let pendingDeleteUrl = '';

    const closeToast = function() {
        toast.classList.remove('is-open');
        toast.setAttribute('aria-hidden', 'true');
        pendingDeleteUrl = '';
    };

    const openToastForLink = function(link) {
        pendingDeleteUrl = link.getAttribute('href') || '';
        messageNode.textContent = link.getAttribute('data-confirm-message') || 'Delete this item?';
        confirmBtn.textContent = link.getAttribute('data-confirm-action') || 'Delete';
        toast.classList.add('is-open');
        toast.setAttribute('aria-hidden', 'false');
        confirmBtn.focus();
    };

    document.addEventListener('click', function(e) {
        const deleteTrigger = e.target.closest('.js-elearn-confirm-delete');
        if (!deleteTrigger) {
            return;
        }
        e.preventDefault();
        openToastForLink(deleteTrigger);
    });

    closeBtn.addEventListener('click', closeToast);
    cancelBtn.addEventListener('click', closeToast);

    confirmBtn.addEventListener('click', function() {
        if (pendingDeleteUrl) {
            window.location.assign(pendingDeleteUrl);
            return;
        }
        closeToast();
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && toast.classList.contains('is-open')) {
            closeToast();
        }
    });
});
</script>

<script>
(function() {
    const shell = document.getElementById('elearnAdminShell');
    const toggle = document.getElementById('elearnSidebarToggle');
    const overlay = document.getElementById('elearnSidebarOverlay');
    if (!shell || !toggle || !overlay) {
        return;
    }

    const storageKey = 'elearningAdminSidebarCollapsed';
    const mq = window.matchMedia('(max-width: 991.98px)');
    const sidebar = document.getElementById('elearnSidebar');

    const applyDesktopState = function() {
        const collapsed = window.localStorage.getItem(storageKey) === '1';
        shell.classList.toggle('is-collapsed', collapsed);
        toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    };

    const closeMobile = function() {
        shell.classList.remove('is-mobile-open');
    };

    const openMobile = function() {
        shell.classList.add('is-mobile-open');
    };

    if (!mq.matches) {
        applyDesktopState();
    }

    if (sidebar) {
        sidebar.addEventListener('mouseenter', function() {
            if (!mq.matches && shell.classList.contains('is-collapsed')) {
                shell.classList.add('is-hover-open');
            }
        });

        sidebar.addEventListener('mouseleave', function() {
            shell.classList.remove('is-hover-open');
        });
    }

    toggle.addEventListener('click', function() {
        if (mq.matches) {
            if (shell.classList.contains('is-mobile-open')) {
                closeMobile();
            } else {
                openMobile();
            }
            return;
        }

        const collapsed = !shell.classList.contains('is-collapsed');
        shell.classList.remove('is-hover-open');
        shell.classList.toggle('is-collapsed', collapsed);
        window.localStorage.setItem(storageKey, collapsed ? '1' : '0');
        toggle.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    });

    overlay.addEventListener('click', closeMobile);

    window.addEventListener('resize', function() {
        if (mq.matches) {
            shell.classList.remove('is-collapsed');
            shell.classList.remove('is-hover-open');
        } else {
            closeMobile();
            shell.classList.remove('is-hover-open');
            applyDesktopState();
        }
    });

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && shell.classList.contains('is-mobile-open')) {
            closeMobile();
        }
    });
})();
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    if (window.localElearningAdminChatbotInit) {
        return;
    }
    window.localElearningAdminChatbotInit = true;

    const body = document.body;
    if (!body) {
        return;
    }

    const fab = document.createElement('button');
    fab.type = 'button';
    fab.id = 'eaChatbotFab';
    fab.className = 'ea-chatbot-fab';
    fab.setAttribute('aria-label', 'Open admin assistant');
    fab.innerHTML = '<i class="fa fa-robot"></i>';

    const panel = document.createElement('div');
    panel.id = 'eaChatbotPanel';
    panel.className = 'ea-chatbot-panel d-none';
    panel.innerHTML = '' +
        '<div class="ea-chatbot-head">' +
            '<strong>Assistant IA Admin</strong>' +
            '<button type="button" id="eaChatbotClose" class="ea-chatbot-close" aria-label="Close">&times;</button>' +
        '</div>' +
        '<div id="eaChatbotMessages" class="ea-chatbot-messages">' +
            '<div class="ea-chatbot-msg ea-chatbot-msg-bot">Exemple: saif cours physique, ou facture saif pour cours physique.</div>' +
        '</div>' +
        '<form id="eaChatbotForm" class="ea-chatbot-form">' +
            '<input id="eaChatbotInput" type="text" class="form-control" placeholder="Requete admin..." autocomplete="off">' +
            '<button type="submit" class="btn btn-primary">Envoyer</button>' +
        '</form>';

    body.appendChild(fab);
    body.appendChild(panel);

    const closeBtn = document.getElementById('eaChatbotClose');
    const form = document.getElementById('eaChatbotForm');
    const input = document.getElementById('eaChatbotInput');
    const messages = document.getElementById('eaChatbotMessages');

    const appendMessage = function(text, isBot) {
        if (!messages) {
            return;
        }
        const msg = document.createElement('div');
        msg.className = 'ea-chatbot-msg ' + (isBot ? 'ea-chatbot-msg-bot' : 'ea-chatbot-msg-user');
        msg.textContent = text;
        messages.appendChild(msg);
        messages.scrollTop = messages.scrollHeight;
    };

    const appendMeta = function() {
        if (!messages) {
            return null;
        }
        const meta = document.createElement('div');
        meta.className = 'ea-chatbot-meta';
        messages.appendChild(meta);
        messages.scrollTop = messages.scrollHeight;
        return meta;
    };

    const renderSuggestions = function(meta, suggestions, askFn) {
        if (!meta || !Array.isArray(suggestions) || !suggestions.length) {
            return;
        }
        const wrap = document.createElement('div');
        wrap.className = 'ea-chatbot-suggestions';

        suggestions.slice(0, 3).forEach(function(suggestion) {
            if (!suggestion || typeof suggestion !== 'string') {
                return;
            }
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'ea-chatbot-suggestion-btn';
            btn.textContent = suggestion;
            btn.addEventListener('click', function() {
                askFn(suggestion);
            });
            wrap.appendChild(btn);
        });

        if (wrap.childNodes.length > 0) {
            meta.appendChild(wrap);
        }
    };

    const renderInvoiceButton = function(meta, invoiceurl, label) {
        if (!meta || !invoiceurl) {
            return;
        }
        const box = document.createElement('div');
        box.className = 'ea-chatbot-invoice';

        const link = document.createElement('a');
        link.href = invoiceurl;
        link.className = 'btn btn-sm btn-outline-primary';
        link.textContent = label || 'Telecharger facture';
        box.appendChild(link);

        meta.appendChild(box);
    };

    const askAdminBot = function(question) {
        const text = (question || '').trim();
        if (!text) {
            return;
        }
        appendMessage(text, false);
        if (input) {
            input.value = '';
        }

        const wwwroot = (window.M && M.cfg && M.cfg.wwwroot) ? M.cfg.wwwroot : '';
        const sesskey = (window.M && M.cfg && M.cfg.sesskey) ? M.cfg.sesskey : '';
        const endpoint = wwwroot + '/local/elearning_system/admin/chatbot.php';

        if (!wwwroot || !sesskey) {
            appendMessage('Session invalide. Rechargez la page puis reessayez.', true);
            return;
        }

        fetch(endpoint, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: new URLSearchParams({
                sesskey: sesskey,
                message: text
            }).toString()
        })
        .then(function(res) {
            return res.json();
        })
        .then(function(data) {
            const reply = (data && data.reply) ? data.reply : 'Reponse indisponible.';
            appendMessage(reply, true);
            const meta = appendMeta();
            renderInvoiceButton(meta, data ? data.invoiceurl : '', data ? data.invoicelabel : '');
            renderSuggestions(meta, data && data.suggestions ? data.suggestions : [], askAdminBot);
        })
        .catch(function() {
            appendMessage('Erreur reseau. Reessayez.', true);
        });
    };

    fab.addEventListener('click', function() {
        panel.classList.toggle('d-none');
        if (!panel.classList.contains('d-none') && input) {
            input.focus();
        }
    });

    if (closeBtn) {
        closeBtn.addEventListener('click', function() {
            panel.classList.add('d-none');
        });
    }

    if (form) {
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            askAdminBot(input ? input.value : '');
        });
    }
});
</script>
