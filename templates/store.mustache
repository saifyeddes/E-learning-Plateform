<div class="container mt-5">
    <div class="row">
        <div class="col-12">
            <h2 class="mb-4">Available Courses</h2>

            {{#hascourses}}
            <div class="row g-4 mb-5">
                {{#courses}}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 d-flex flex-column shadow-sm">
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 160px; overflow: hidden;">
                            {{#hasimage}}
                            <a href="{{producturl}}" class="w-100 h-100" style="display: flex; align-items: center; justify-content: center;">
                                <img src="{{image}}" alt="{{name}}" class="img-fluid rounded" style="max-height: 160px; object-fit: cover;">
                            </a>
                            {{/hasimage}}
                            {{^hasimage}}
                            <a href="{{producturl}}" class="text-decoration-none">
                                <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                            </a>
                            {{/hasimage}}
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1"><a href="{{producturl}}" class="text-decoration-none text-dark">{{name}}</a></h5>
                            {{#hascoursefullname}}
                            <div class="small text-muted mb-2">Course: {{coursefullname}}</div>
                            {{/hascoursefullname}}

                            <div class="mb-2">
                                <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">
                                    {{#isfree}}Free{{/isfree}}
                                    {{#ispaid}}Paid{{/ispaid}}
                                </span>
                            </div>

                            <div class="mb-3">
                                {{#isfree}}
                                <strong>Price:</strong> Free
                                {{/isfree}}
                                {{#ispaid}}
                                <strong>Price:</strong>
                                {{#saleprice}}${{saleprice}}{{/saleprice}}
                                {{^saleprice}}${{price}}{{/saleprice}}
                                {{/ispaid}}
                            </div>

                            <div class="card-footer bg-light border-top-0 mt-auto pt-0">
                                {{#isloggedin}}
                                <a href="{{producturl}}" class="btn btn-primary w-100">Buy Now</a>
                                {{/isloggedin}}
                                {{^isloggedin}}
                                <a href="{{loginurl}}" class="btn btn-primary w-100">Login to Buy</a>
                                {{/isloggedin}}
                            </div>
                        </div>
                    </div>
                </div>
                {{/courses}}
            </div>
            {{/hascourses}}

            {{^hascourses}}
            <div class="alert alert-info mb-5" role="alert">
                No courses available at this time.
            </div>
            {{/hascourses}}

            <h2 class="mb-4">Available Products</h2>

            {{#hasproducts}}
            <div class="row g-4">
                {{#products}}
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 d-flex flex-column shadow-sm">
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 160px; overflow: hidden;">
                            {{#hasimage}}
                            <a href="{{producturl}}" class="w-100 h-100" style="display: flex; align-items: center; justify-content: center;">
                                <img src="{{image}}" alt="{{name}}" class="img-fluid rounded" style="max-height: 160px; object-fit: cover;">
                            </a>
                            {{/hasimage}}
                            {{^hasimage}}
                            <a href="{{producturl}}" class="text-decoration-none">
                                <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                            </a>
                            {{/hasimage}}
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1"><a href="{{producturl}}" class="text-decoration-none text-dark">{{name}}</a></h5>

                            <div class="mb-2">
                                <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">
                                    {{#isfree}}Free{{/isfree}}
                                    {{#ispaid}}Paid{{/ispaid}}
                                </span>
                            </div>

                            <div class="mb-3">
                                {{#isfree}}
                                <strong>Price:</strong> Free
                                {{/isfree}}
                                {{#ispaid}}
                                <strong>Price:</strong>
                                {{#saleprice}}${{saleprice}}{{/saleprice}}
                                {{^saleprice}}${{price}}{{/saleprice}}
                                {{/ispaid}}
                            </div>

                            <div class="card-footer bg-light border-top-0 mt-auto pt-0">
                                {{#isloggedin}}
                                <a href="{{producturl}}" class="btn btn-primary w-100">
                                    Buy Now
                                </a>
                                {{/isloggedin}}
                                {{^isloggedin}}
                                <a href="{{loginurl}}" class="btn btn-primary w-100">
                                    Login to Buy
                                </a>
                                {{/isloggedin}}
                            </div>
                        </div>
                    </div>
                </div>
                {{/products}}
            </div>
            {{/hasproducts}}

            {{^hasproducts}}
            <div class="alert alert-info" role="alert">
                No products available at this time.
            </div>
            {{/hasproducts}}
        </div>
    </div>
</div>
