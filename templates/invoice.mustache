<div class="container mt-4">

    <div class="row mb-4">
        <div class="col-12">
            <a href="{{backurl}}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left"></i> Retour
            </a>
            <a href="{{pdfurl}}" class="btn btn-success float-end">
                <i class="fa fa-download"></i> Télécharger PDF
            </a>
        </div>
    </div>

    {{#isparentaccount}}
    <div class="alert alert-info">
        Facture de votre enfant: <strong>{{targetfullname}}</strong>
    </div>
    {{/isparentaccount}}

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow-sm">
                <div class="card-body p-4">
                    
                    <!-- Header -->
                    <div class="text-center mb-5">
                        <h2 class="mb-1">FACTURE</h2>
                        <p class="text-muted">Facture #{{id}}</p>
                    </div>

                    <!-- Issue Date -->
                    <div class="row mb-4">
                        <div class="col-6">
                            <p class="mb-1"><strong>Date d'émission:</strong></p>
                            <p>{{timecreated}}</p>
                        </div>
                    </div>

                    <!-- Client Info -->
                    {{#user}}
                    <div class="border-top border-bottom py-3 mb-4">
                        <p class="mb-1"><strong>Client:</strong></p>
                        <p class="mb-0">{{user.fullname}}</p>
                        <p class="mb-0 text-muted">{{user.email}}</p>
                    </div>
                    {{/user}}

                    <!-- Items Table -->
                    <div class="mb-4">
                        <table class="table">
                            <thead class="table-light">
                                <tr>
                                    <th>Produit / Service</th>
                                    <th class="text-center" style="width:80px;">Quantité</th>
                                    <th class="text-end" style="width:120px;">Montant</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#product}}
                                <tr>
                                    <td>{{product.name}}</td>
                                    <td class="text-center">1</td>
                                    <td class="text-end">${{product.amount}}</td>
                                </tr>
                                {{/product}}
                            </tbody>
                        </table>
                    </div>

                    <!-- Totals -->
                    <div class="row mb-4">
                        <div class="col-6 offset-6">
                            <table class="table table-sm border-top">
                                <tbody>
                                    <tr>
                                        <th class="text-end" style="width:50%;">Sous-total:</th>
                                        <td class="text-end">${{subtotal}}</td>
                                    </tr>
                                    {{#hastvapercent}}
                                    <tr>
                                        <th class="text-end">TVA ({{tvapercent}}%):</th>
                                        <td class="text-end">${{taxamount}}</td>
                                    </tr>
                                    {{/hastvapercent}}
                                    <tr class="border-top">
                                        <th class="text-end fs-5">Total:</th>
                                        <td class="text-end fs-5 text-success"><strong>${{total}}</strong></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="text-center text-muted mt-5 pt-4 border-top">
                        <p class="small mb-0">Merci pour votre achat!</p>
                        <p class="small mb-0">Pour toute question, veuillez nous contacter.</p>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>
