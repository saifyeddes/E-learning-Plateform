<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h3 class="mb-0">Mes cours et commandes</h3>
            <div class="d-flex gap-2">
                <a href="{{homeurl}}" class="btn btn-outline-primary btn-sm">Catalogue</a>
                <a href="{{carturl}}" class="btn btn-outline-secondary btn-sm">Panier</a>
                <a href="{{commandesurl}}" class="btn btn-info btn-sm">
                    <i class="fa fa-list"></i> Commandes
                </a>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><strong>Cours achetés</strong></div>
        <div class="card-body">
            {{#hascourses}}
            <div class="row g-4">
                {{#courses}}
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm overflow-hidden">
                        {{#hasproductimage}}
                        <div class="position-relative" style="height:200px; overflow:hidden;">
                            <img src="{{productimage}}" alt="{{coursename}}" class="img-fluid w-100 h-100" style="object-fit:cover;">
                        </div>
                        {{/hasproductimage}}
                        {{^hasproductimage}}
                        <div class="bg-light w-100" style="height:200px; display:flex; align-items:center; justify-content:center;">
                            <div class="text-muted text-center">
                                <i class="fa fa-image fa-2x"></i>
                                <p class="mt-2">Pas d'image</p>
                            </div>
                        </div>
                        {{/hasproductimage}}
                        
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title">{{coursename}}</h6>
                            {{#showproductname}}
                            <div class="text-muted small mb-2">{{productname}}</div>
                            {{/showproductname}}
                            <div class="text-muted small mb-3">
                                <i class="fa fa-calendar"></i> {{purchaseat}}
                            </div>
                            <a href="{{courseurl}}" class="btn btn-success btn-sm mt-auto">
                                <i class="fa fa-play"></i> Démarrer le cours
                            </a>
                        </div>
                    </div>
                </div>
                {{/courses}}
            </div>
            {{/hascourses}}
            {{^hascourses}}
            <div class="alert alert-info mb-0">Aucun cours acheté pour le moment.</div>
            {{/hascourses}}
        </div>
    </div>

    <div class="alert alert-info mt-4" role="alert">
        <i class="fa fa-info-circle"></i> Pour voir toutes vos commandes avec détails complets et télécharger vos factures, visitez la <a href="{{commandesurl}}" class="alert-link">page des commandes</a>.
    </div>

</div>
