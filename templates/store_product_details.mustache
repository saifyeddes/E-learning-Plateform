<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <a href="{{backurl}}" class="btn btn-outline-secondary">
                <i class="fa fa-arrow-left"></i> Back to Store
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            {{#hasimage}}
            <img src="{{image}}" alt="{{name}}" class="img-fluid rounded shadow-sm">
            {{/hasimage}}
            {{^hasimage}}
            <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 300px;">
                <div class="text-muted text-center">
                    <i class="fa fa-image fa-3x"></i>
                    <p>No image</p>
                </div>
            </div>
            {{/hasimage}}
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h1 class="card-title mb-3">{{name}}</h1>

                    <div class="mb-3">
                        <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}} fs-6">
                            {{#isfree}}Free{{/isfree}}
                            {{#ispaid}}Paid{{/ispaid}}
                        </span>
                    </div>

                    <div class="mb-4 p-3 bg-light rounded">
                        {{#isfree}}
                        <p class="mb-0"><strong>Price:</strong> <span class="text-success fs-5">Free</span></p>
                        {{/isfree}}
                        {{#ispaid}}
                        <p class="mb-0"><strong>Price:</strong></p>
                        {{#saleprice}}
                        <p class="mb-0">
                            <span class="text-muted"><s>${{price}}</s></span>
                            <span class="text-danger fs-5">${{saleprice}}</span>
                        </p>
                        {{/saleprice}}
                        {{^saleprice}}
                        <p class="mb-0"><span class="text-danger fs-5">${{price}}</span></p>
                        {{/saleprice}}
                        {{/ispaid}}
                    </div>

                    {{#categoryname}}
                    <div class="mb-3">
                        <strong>Category:</strong> {{categoryname}}
                    </div>
                    {{/categoryname}}

                    {{#hascourse}}
                    <div class="mb-4">
                        <strong>Course:</strong> {{coursename}}
                    </div>
                    {{/hascourse}}

                    {{#description}}
                    <div class="mb-4">
                        <h5>Description</h5>
                        <p class="text-muted">{{description}}</p>
                    </div>
                    {{/description}}
                    {{^description}}
                    <div class="mb-4">
                        <p class="text-muted"><em>No description available</em></p>
                    </div>
                    {{/description}}

                    {{#hascourse}}
                    {{#isloggedin}}
                    <a href="{{courseurl}}" class="btn btn-success btn-lg">
                        <i class="fa fa-play"></i> Open Course
                    </a>
                    {{/isloggedin}}
                    {{^isloggedin}}
                    <a href="{{loginurl}}" class="btn btn-primary btn-lg">
                        <i class="fa fa-sign-in"></i> Login to Access Course
                    </a>
                    {{/isloggedin}}
                    {{/hascourse}}
                </div>
            </div>
        </div>
    </div>
</div>
