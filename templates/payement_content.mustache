<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Payement TVA</h3>
</div>

<div class="card border-0 shadow-sm" style="max-width: 720px;">
    <div class="card-body">
        <p class="text-muted mb-3">Set one global TVA (%) for this client. The same TVA is applied to all products and all bundles at checkout.</p>

        {{#hassuccessmessage}}
        <div class="alert alert-success">{{successmessage}}</div>
        {{/hassuccessmessage}}

        {{#haserrors}}
        <div class="alert alert-danger">
            <ul class="mb-0">
                {{#errors}}
                <li>{{.}}</li>
                {{/errors}}
            </ul>
        </div>
        {{/haserrors}}

        <form method="post" action="{{payementurl}}" class="row g-3 align-items-end">
            <input type="hidden" name="sesskey" value="{{sesskey}}">

            <div class="col-md-6">
                <label class="form-label"><strong>TVA (%)</strong></label>
                <input type="number"
                       name="tvapercent"
                       class="form-control"
                       value="{{tvapercent}}"
                       min="0"
                       max="100"
                       step="0.01"
                       placeholder="e.g., 20">
            </div>

            <div class="col-md-6">
                <button type="submit" class="btn btn-primary">Save TVA</button>
            </div>
        </form>
    </div>
</div>
