{{> local_elearning_system/client_styles }}
<div class="es-client">
<div class="container-fluid">
    <div class="mb-3">
        <a href="{{backurl}}" class="btn btn-link p-0">Back to courses</a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="row">
                <div class="col-12 col-lg-4 mb-3 mb-lg-0 text-center">
                    {{#hasimage}}
                    <img src="{{image}}" alt="{{name}}" class="img-fluid rounded" style="max-height: 300px; object-fit: cover;">
                    {{/hasimage}}
                    {{^hasimage}}
                    <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                    {{/hasimage}}
                </div>

                <div class="col-12 col-lg-8">
                    <h2 class="mb-2">{{name}}</h2>

                    <p class="mb-2">
                        <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">{{type}}</span>
                    </p>

                    <p class="mb-2">
                        {{#isfree}}
                        <strong>Price:</strong> Free
                        {{/isfree}}
                        {{#ispaid}}
                        <strong>Price:</strong>
                        {{#saleprice}}{{saleprice}}{{/saleprice}}
                        {{^saleprice}}{{price}}{{/saleprice}}
                        {{/ispaid}}
                    </p>

                    <p class="mb-2"><strong>Category:</strong> {{categoryname}}</p>
                    <p class="mb-3"><strong>Course:</strong> {{coursename}}</p>

                    {{#isbundle}}
                    <div class="mb-3">
                        <h5 class="mb-2">Bundle products</h5>
                        {{#hasbundleitems}}
                        <ul class="list-group">
                            {{#bundleitems}}
                            <li class="list-group-item d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <div><strong>{{name}}</strong></div>
                                    <div class="small text-muted">
                                        {{#hascourse}}<a href="{{courseurl}}">{{coursename}}</a>{{/hascourse}}
                                        {{^hascourse}}{{coursename}}{{/hascourse}}
                                    </div>
                                </div>
                                {{#ispurchased}}<span class="badge bg-success">Purchased</span>{{/ispurchased}}
                                {{^ispurchased}}<span class="badge bg-secondary">Not purchased</span>{{/ispurchased}}
                            </li>
                            {{/bundleitems}}
                        </ul>
                        {{/hasbundleitems}}
                        {{^hasbundleitems}}
                        <p class="text-muted mb-0">No products assigned to this bundle.</p>
                        {{/hasbundleitems}}
                    </div>
                    {{/isbundle}}

                    <div class="mb-4">
                        <h5>Description</h5>
                        {{#hasdescription}}
                        <div>{{{description}}}</div>
                        {{/hasdescription}}
                        {{^hasdescription}}
                        <p class="text-muted mb-0">No description available.</p>
                        {{/hasdescription}}
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        {{#ispurchased}}
                        <span class="btn btn-success disabled" aria-disabled="true">Purchased</span>
                        {{/ispurchased}}
                        {{^ispurchased}}
                            {{#isincart}}
                            <a href="{{carturl}}" class="btn btn-outline-primary">In cart</a>
                            {{/isincart}}
                            {{^isincart}}
                            <a href="{{addtocarturl}}" class="btn btn-primary">Add to Cart</a>
                            {{/isincart}}
                        {{/ispurchased}}
                        <a href="{{carturl}}" class="btn btn-outline-primary">View Cart</a>
                        {{#hascourse}}
                        {{#isloggedin}}
                        <a href="{{courseurl}}" class="btn btn-outline-secondary">Open Course</a>
                        {{/isloggedin}}
                        {{^isloggedin}}
                        <a href="{{authurl}}" class="btn btn-success">Buy Now</a>
                        {{/isloggedin}}
                        {{/hascourse}}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
