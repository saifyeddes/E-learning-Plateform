{{> local_elearning_system/client_styles }}
<div class="es-client">
<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <div class="es-home-hero d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h3 class="mb-1">{{home_allcourses}}</h3>
                    <p class="text-muted mb-0">{{home_homeintro}}</p>
                </div>
                <div class="es-top-actions">
                    <a href="{{carturl}}" class="es-cart-icon-btn" title="{{home_cart}}" aria-label="{{home_cart}}">
                        <i class="fa fa-shopping-cart"></i>
                        <span class="es-cart-count">{{cartcount}}</span>
                    </a>
                    {{#isloggedin}}
                    <a href="{{mycoursesurl}}" class="btn btn-light btn-sm">
                        {{home_mycourses}}
                    </a>
                    {{/isloggedin}}
                </div>
            </div>
        </div>
    </div>

    <section class="es-home-carousel card mb-3" aria-label="Site presentation">
        <div class="es-home-carousel-inner" id="esHomeCarousel">
            <article class="es-home-slide is-active">
                <div class="es-home-slide-content">
                    <span class="es-home-slide-kicker">{{home_homeslide1kicker}}</span>
                    <h2>{{home_homeslide1title}}</h2>
                    <p>{{home_homeslide1desc}}</p>
                    <div class="es-home-slide-actions">
                        <a href="#homeCourseList" class="btn btn-primary">{{home_browsecourses}}</a>
                        {{#isloggedin}}
                        <a href="{{mycoursesurl}}" class="btn btn-outline-secondary">{{home_mycourses}}</a>
                        {{/isloggedin}}
                        {{^isloggedin}}
                        <a href="{{loginurl}}" class="btn btn-outline-secondary">{{home_signin}}</a>
                        {{/isloggedin}}
                    </div>
                </div>
                <div class="es-home-slide-art" aria-hidden="true">
                    <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=900&q=80" alt="Students learning in classroom" loading="eager">
                </div>
            </article>

            <article class="es-home-slide">
                <div class="es-home-slide-content">
                    <span class="es-home-slide-kicker">{{home_homeslide2kicker}}</span>
                    <h2>{{home_homeslide2title}}</h2>
                    <p>{{home_homeslide2desc}}</p>
                    <div class="es-home-slide-actions">
                        <a href="#homeBundleList" class="btn btn-primary">{{home_viewbundles}}</a>
                        <a href="{{carturl}}" class="btn btn-outline-secondary">{{home_opencart}}</a>
                    </div>
                </div>
                <div class="es-home-slide-art" aria-hidden="true">
                    <img src="https://images.unsplash.com/photo-1513258496099-48168024aec0?auto=format&fit=crop&w=900&q=80" alt="Students collaborating around educational material" loading="lazy">
                </div>
            </article>

            <article class="es-home-slide">
                <div class="es-home-slide-content">
                    <span class="es-home-slide-kicker">{{home_homeslide3kicker}}</span>
                    <h2>{{home_homeslide3title}}</h2>
                    <p>{{home_homeslide3desc}}</p>
                    <div class="es-home-slide-actions">
                        <a href="#homeFilters" class="btn btn-primary">{{home_findacourse}}</a>
                        <a href="{{carturl}}" class="btn btn-outline-secondary">{{home_checkout}}</a>
                    </div>
                </div>
                <div class="es-home-slide-art" aria-hidden="true">
                    <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?auto=format&fit=crop&w=900&q=80" alt="Student using laptop for online learning" loading="lazy">
                </div>
            </article>
        </div>

        <div class="es-home-carousel-nav" aria-label="Carousel navigation">
            <button type="button" class="es-home-carousel-btn" id="esHomePrev" aria-label="Previous slide">
                <i class="fa fa-chevron-left"></i>
            </button>
            <div class="es-home-carousel-dots" id="esHomeDots"></div>
            <button type="button" class="es-home-carousel-btn" id="esHomeNext" aria-label="Next slide">
                <i class="fa fa-chevron-right"></i>
            </button>
        </div>
    </section>

    {{#hasproducts}}
    <div class="card mb-3 es-home-filters">
        <div class="card-body">
            <div class="row g-2 align-items-end" id="homeFilters">
                <div class="col-12 col-md-6">
                    <label for="homeSearch" class="form-label mb-1">{{home_search}}</label>
                    <input type="text" id="homeSearch" class="form-control" placeholder="{{home_searchbycoursename}}">
                </div>
                <div class="col-12 col-md-4">
                    <label for="homeTypeFilter" class="form-label mb-1">{{home_type}}</label>
                    <select id="homeTypeFilter" class="custom-select form-control">
                        <option value="all">{{home_alltypes}}</option>
                        <option value="free">{{home_free}}</option>
                        <option value="paid">{{home_paid}}</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="button" id="homeResetFilter" class="btn btn-secondary w-100">{{home_reset}}</button>
                </div>
            </div>
        </div>
    </div>
    {{/hasproducts}}

    <div class="row g-3" id="homeCourseList">
        {{#products}}
        <div class="col-12 col-sm-6 col-lg-4 mb-3 home-course-item" data-type="{{#isfree}}free{{/isfree}}{{#ispaid}}paid{{/ispaid}}" data-name="{{name}}">
            <div class="card h-100 es-store-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-center es-store-image-wrap">
                        {{#hasimage}}
                        <a href="{{producturl}}">
                            <img src="{{image}}" alt="{{name}}" class="img-fluid rounded es-store-image">
                        </a>
                        {{/hasimage}}
                        {{^hasimage}}
                        <a href="{{producturl}}" class="text-decoration-none es-store-image-placeholder">
                            <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                        </a>
                        {{/hasimage}}
                    </div>

                    <h5 class="card-title mb-1"><a href="{{producturl}}">{{name}}</a></h5>

                    <div class="mb-2">
                        <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">
                            {{#isfree}}{{home_free}}{{/isfree}}
                            {{#ispaid}}{{home_paid}}{{/ispaid}}
                        </span>
                    </div>

                    <div class="mb-3 es-store-price">
                        {{#isfree}}
                        <strong>{{home_pricelabel}}:</strong> {{home_free}}
                        {{/isfree}}
                        {{#ispaid}}
                        <strong>{{home_pricelabel}}:</strong>
                        {{#saleprice}}{{saleprice}}{{/saleprice}}
                        {{^saleprice}}{{price}}{{/saleprice}}
                        {{/ispaid}}
                    </div>

                    {{#ispurchased}}
                    <span class="btn btn-success mt-auto disabled es-store-cta" aria-disabled="true">{{home_purchased}}</span>
                    {{/ispurchased}}
                    {{^ispurchased}}
                        {{#isincart}}
                        <a href="{{carturl}}" class="btn btn-outline-primary mt-auto es-store-cta">{{home_incart}}</a>
                        {{/isincart}}
                        {{^isincart}}
                        <a href="{{addtocarturl}}" class="btn btn-primary mt-auto es-store-cta">{{home_addtocart}}</a>
                        {{/isincart}}
                    {{/ispurchased}}
                </div>
            </div>
        </div>
        {{/products}}
    </div>

    {{^products}}
    <div class="alert alert-info">
        {{home_nocoursesavailable}}
    </div>
    {{/products}}

    <hr class="my-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="mb-1">{{home_availablebundles}}</h3>
            <p class="text-muted mb-0">{{home_bundlesdesc}}</p>
        </div>
    </div>

    {{#hasbundles}}
    <div class="row g-3" id="homeBundleList">
        {{#bundles}}
        <div class="col-12 col-sm-6 col-lg-4 mb-3">
            <div class="card h-100 es-store-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-center es-store-image-wrap">
                        {{#hasimage}}
                        <a href="{{producturl}}">
                            <img src="{{image}}" alt="{{name}}" class="img-fluid rounded es-store-image">
                        </a>
                        {{/hasimage}}
                        {{^hasimage}}
                        <a href="{{producturl}}" class="text-decoration-none es-store-image-placeholder">
                            <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                        </a>
                        {{/hasimage}}
                    </div>

                    <h5 class="card-title mb-1"><a href="{{producturl}}">{{name}}</a></h5>

                    <div class="mb-2 d-flex align-items-center gap-2">
                        <span class="badge bg-info text-dark">{{home_bundle}}</span>
                        <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">
                            {{#isfree}}{{home_free}}{{/isfree}}
                            {{#ispaid}}{{home_paid}}{{/ispaid}}
                        </span>
                    </div>

                    <div class="mb-3 es-store-price">
                        {{#isfree}}
                        <strong>{{home_pricelabel}}:</strong> {{home_free}}
                        {{/isfree}}
                        {{#ispaid}}
                        <strong>{{home_pricelabel}}:</strong>
                        {{#saleprice}}{{saleprice}}{{/saleprice}}
                        {{^saleprice}}{{price}}{{/saleprice}}
                        {{/ispaid}}
                    </div>

                    {{#ispurchased}}
                    <span class="btn btn-success mt-auto disabled es-store-cta" aria-disabled="true">{{home_purchased}}</span>
                    {{/ispurchased}}
                    {{^ispurchased}}
                        {{#isincart}}
                        <a href="{{carturl}}" class="btn btn-outline-primary mt-auto es-store-cta">{{home_incart}}</a>
                        {{/isincart}}
                        {{^isincart}}
                        <a href="{{addtocarturl}}" class="btn btn-primary mt-auto es-store-cta">{{home_addtocart}}</a>
                        {{/isincart}}
                    {{/ispurchased}}
                </div>
            </div>
        </div>
        {{/bundles}}
    </div>
    {{/hasbundles}}

    {{^hasbundles}}
    <div class="alert alert-info">
        {{home_nobundlesavailable}}
    </div>
    {{/hasbundles}}

    <div id="homeNoResults" class="alert alert-warning d-none mt-2">
        {{home_nocoursesmatch}}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const carouselRoot = document.getElementById('esHomeCarousel');
    const carouselPrev = document.getElementById('esHomePrev');
    const carouselNext = document.getElementById('esHomeNext');
    const carouselDots = document.getElementById('esHomeDots');

    if (carouselRoot && carouselPrev && carouselNext && carouselDots) {
        const slides = Array.from(carouselRoot.querySelectorAll('.es-home-slide'));
        let activeIndex = Math.max(0, slides.findIndex(function(slide) {
            return slide.classList.contains('is-active');
        }));
        let timer = null;

        const renderDots = function() {
            carouselDots.innerHTML = '';
            slides.forEach(function(_, idx) {
                const dot = document.createElement('button');
                dot.type = 'button';
                dot.className = 'es-home-dot';
                dot.setAttribute('aria-label', 'Go to slide ' + (idx + 1));
                dot.classList.toggle('is-active', idx === activeIndex);
                dot.addEventListener('click', function() {
                    setActive(idx);
                    restartTimer();
                });
                carouselDots.appendChild(dot);
            });
        };

        const setActive = function(index) {
            activeIndex = (index + slides.length) % slides.length;
            slides.forEach(function(slide, idx) {
                slide.classList.toggle('is-active', idx === activeIndex);
            });
            Array.from(carouselDots.querySelectorAll('.es-home-dot')).forEach(function(dot, idx) {
                dot.classList.toggle('is-active', idx === activeIndex);
            });
        };

        const nextSlide = function() {
            setActive(activeIndex + 1);
        };

        const prevSlide = function() {
            setActive(activeIndex - 1);
        };

        const restartTimer = function() {
            if (timer) {
                clearInterval(timer);
            }
            timer = setInterval(nextSlide, 2000);
        };

        carouselNext.addEventListener('click', function() {
            nextSlide();
            restartTimer();
        });

        carouselPrev.addEventListener('click', function() {
            prevSlide();
            restartTimer();
        });

        carouselRoot.addEventListener('mouseenter', function() {
            if (timer) {
                clearInterval(timer);
            }
        });

        carouselRoot.addEventListener('mouseleave', function() {
            restartTimer();
        });

        renderDots();
        setActive(activeIndex);
        restartTimer();
    }

    const searchInput = document.getElementById('homeSearch');
    const typeFilter = document.getElementById('homeTypeFilter');
    const resetBtn = document.getElementById('homeResetFilter');
    const items = Array.from(document.querySelectorAll('.home-course-item'));
    const noResults = document.getElementById('homeNoResults');

    if (!items.length || !searchInput || !typeFilter || !resetBtn || !noResults) {
        return;
    }

    const applyFilters = function() {
        const query = searchInput.value.trim().toLowerCase();
        const selectedType = typeFilter.value;
        let visibleCount = 0;

        items.forEach(function(item) {
            const name = (item.getAttribute('data-name') || '').toLowerCase();
            const type = item.getAttribute('data-type') || '';

            const matchName = query === '' || name.indexOf(query) !== -1;
            const matchType = selectedType === 'all' || type === selectedType;

            const isVisible = matchName && matchType;
            item.classList.toggle('d-none', !isVisible);
            if (isVisible) {
                visibleCount++;
            }
        });

        noResults.classList.toggle('d-none', visibleCount > 0);
    };

    searchInput.addEventListener('input', applyFilters);
    typeFilter.addEventListener('change', applyFilters);
    resetBtn.addEventListener('click', function() {
        searchInput.value = '';
        typeFilter.value = 'all';
        applyFilters();
    });
});
</script>

</div>

