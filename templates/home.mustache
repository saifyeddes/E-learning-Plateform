{{> local_elearning_system/client_styles }}
<div class="es-client">
<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <div class="es-home-hero d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h3 class="mb-1">All Courses</h3>
                    <p class="text-muted mb-0">Browse available courses and enroll quickly.</p>
                </div>
                <div class="es-top-actions">
                    <a href="{{carturl}}" class="es-cart-icon-btn" title="Panier" aria-label="Panier">
                        <i class="fa fa-shopping-cart"></i>
                        <span class="es-cart-count">{{cartcount}}</span>
                    </a>
                    {{#isloggedin}}
                    <a href="{{mycoursesurl}}" class="btn btn-light btn-sm">
                        My Courses
                    </a>
                    {{/isloggedin}}
                </div>
            </div>
        </div>
    </div>

    {{#hasproducts}}
    <div class="card mb-3 es-home-filters">
        <div class="card-body">
            <div class="row g-2 align-items-end" id="homeFilters">
                <div class="col-12 col-md-6">
                    <label for="homeSearch" class="form-label mb-1">Search</label>
                    <input type="text" id="homeSearch" class="form-control" placeholder="Search by course name">
                </div>
                <div class="col-12 col-md-4">
                    <label for="homeTypeFilter" class="form-label mb-1">Type</label>
                    <select id="homeTypeFilter" class="custom-select form-control">
                        <option value="all">All types</option>
                        <option value="free">Free</option>
                        <option value="paid">Paid</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <button type="button" id="homeResetFilter" class="btn btn-secondary w-100">Reset</button>
                </div>
            </div>
        </div>
    </div>
    {{/hasproducts}}

    <div class="row g-3" id="homeCourseList">
        {{#products}}
        <div class="col-12 col-sm-6 col-lg-4 mb-3 home-course-item" data-type="{{#isfree}}free{{/isfree}}{{#ispaid}}paid{{/ispaid}}" data-name="{{name}}">
            <div class="card h-100 es-store-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-center es-store-image-wrap">
                        {{#hasimage}}
                        <a href="{{producturl}}">
                            <img src="{{image}}" alt="{{name}}" class="img-fluid rounded es-store-image">
                        </a>
                        {{/hasimage}}
                        {{^hasimage}}
                        <a href="{{producturl}}" class="text-decoration-none es-store-image-placeholder">
                            <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                        </a>
                        {{/hasimage}}
                    </div>

                    <h5 class="card-title mb-1"><a href="{{producturl}}">{{name}}</a></h5>

                    <div class="mb-2">
                        <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">
                            {{#isfree}}Free{{/isfree}}
                            {{#ispaid}}Paid{{/ispaid}}
                        </span>
                    </div>

                    <div class="mb-3 es-store-price">
                        {{#isfree}}
                        <strong>Price:</strong> Free
                        {{/isfree}}
                        {{#ispaid}}
                        <strong>Price:</strong>
                        {{#saleprice}}{{saleprice}}{{/saleprice}}
                        {{^saleprice}}{{price}}{{/saleprice}}
                        {{/ispaid}}
                    </div>

                    {{#ispurchased}}
                    <span class="btn btn-success mt-auto disabled es-store-cta" aria-disabled="true">Purchased</span>
                    {{/ispurchased}}
                    {{^ispurchased}}
                        {{#isincart}}
                        <a href="{{carturl}}" class="btn btn-outline-primary mt-auto es-store-cta">In cart</a>
                        {{/isincart}}
                        {{^isincart}}
                        <a href="{{addtocarturl}}" class="btn btn-primary mt-auto es-store-cta">Add to Cart</a>
                        {{/isincart}}
                    {{/ispurchased}}
                </div>
            </div>
        </div>
        {{/products}}
    </div>

    {{^products}}
    <div class="alert alert-info">
        No courses available yet.
    </div>
    {{/products}}

    <hr class="my-4">
    <div class="row mb-3">
        <div class="col-12">
            <h3 class="mb-1">Available Bundles</h3>
            <p class="text-muted mb-0">Buy bundled publications with the same checkout flow.</p>
        </div>
    </div>

    {{#hasbundles}}
    <div class="row g-3" id="homeBundleList">
        {{#bundles}}
        <div class="col-12 col-sm-6 col-lg-4 mb-3">
            <div class="card h-100 es-store-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-center es-store-image-wrap">
                        {{#hasimage}}
                        <a href="{{producturl}}">
                            <img src="{{image}}" alt="{{name}}" class="img-fluid rounded es-store-image">
                        </a>
                        {{/hasimage}}
                        {{^hasimage}}
                        <a href="{{producturl}}" class="text-decoration-none es-store-image-placeholder">
                            <div class="text-muted"><i class="fa fa-image"></i> No image</div>
                        </a>
                        {{/hasimage}}
                    </div>

                    <h5 class="card-title mb-1"><a href="{{producturl}}">{{name}}</a></h5>

                    <div class="mb-2 d-flex align-items-center gap-2">
                        <span class="badge bg-info text-dark">Bundle</span>
                        <span class="badge {{#isfree}}bg-success{{/isfree}}{{#ispaid}}bg-primary{{/ispaid}}">
                            {{#isfree}}Free{{/isfree}}
                            {{#ispaid}}Paid{{/ispaid}}
                        </span>
                    </div>

                    <div class="mb-3 es-store-price">
                        {{#isfree}}
                        <strong>Price:</strong> Free
                        {{/isfree}}
                        {{#ispaid}}
                        <strong>Price:</strong>
                        {{#saleprice}}{{saleprice}}{{/saleprice}}
                        {{^saleprice}}{{price}}{{/saleprice}}
                        {{/ispaid}}
                    </div>

                    {{#ispurchased}}
                    <span class="btn btn-success mt-auto disabled es-store-cta" aria-disabled="true">Purchased</span>
                    {{/ispurchased}}
                    {{^ispurchased}}
                        {{#isincart}}
                        <a href="{{carturl}}" class="btn btn-outline-primary mt-auto es-store-cta">In cart</a>
                        {{/isincart}}
                        {{^isincart}}
                        <a href="{{addtocarturl}}" class="btn btn-primary mt-auto es-store-cta">Add to Cart</a>
                        {{/isincart}}
                    {{/ispurchased}}
                </div>
            </div>
        </div>
        {{/bundles}}
    </div>
    {{/hasbundles}}

    {{^hasbundles}}
    <div class="alert alert-info">
        No bundles available yet.
    </div>
    {{/hasbundles}}

    <div id="homeNoResults" class="alert alert-warning d-none mt-2">
        No courses match your filter.
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('homeSearch');
    const typeFilter = document.getElementById('homeTypeFilter');
    const resetBtn = document.getElementById('homeResetFilter');
    const items = Array.from(document.querySelectorAll('.home-course-item'));
    const noResults = document.getElementById('homeNoResults');

    if (!items.length || !searchInput || !typeFilter || !resetBtn || !noResults) {
        return;
    }

    const applyFilters = function() {
        const query = searchInput.value.trim().toLowerCase();
        const selectedType = typeFilter.value;
        let visibleCount = 0;

        items.forEach(function(item) {
            const name = (item.getAttribute('data-name') || '').toLowerCase();
            const type = item.getAttribute('data-type') || '';

            const matchName = query === '' || name.indexOf(query) !== -1;
            const matchType = selectedType === 'all' || type === selectedType;

            const isVisible = matchName && matchType;
            item.classList.toggle('d-none', !isVisible);
            if (isVisible) {
                visibleCount++;
            }
        });

        noResults.classList.toggle('d-none', visibleCount > 0);
    };

    searchInput.addEventListener('input', applyFilters);
    typeFilter.addEventListener('change', applyFilters);
    resetBtn.addEventListener('click', function() {
        searchInput.value = '';
        typeFilter.value = 'all';
        applyFilters();
    });
});
</script>

</div>

