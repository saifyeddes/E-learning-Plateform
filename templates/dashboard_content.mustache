<div class="row g-4 mb-4">

    <!-- TOTAL PRODUCTS -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small text-uppercase">
                            Total Products
                        </div>
                        <div class="display-6 fw-bold">
                            {{totalproducts}}
                        </div>
                    </div>

                    <div class="text-primary">
                        <i class="fa fa-box fa-2x"></i>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- TOTAL ORDERS -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small text-uppercase">
                            Total Orders
                        </div>
                        <div class="display-6 fw-bold">
                            {{totalorders}}
                        </div>
                    </div>

                    <div class="text-success">
                        <i class="fa fa-shopping-cart fa-2x"></i>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- TOTAL REVENUE -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">

                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-muted small text-uppercase">
                            Total Revenue
                        </div>
                        <div class="display-6 fw-bold">
                            {{totalrevenue}}
                        </div>
                    </div>

                    <div class="text-warning">
                        <i class="fa fa-dollar-sign fa-2x"></i>
                    </div>
                </div>

            </div>
        </div>
    </div>

</div>

<div class="row g-4">

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="text-muted small text-uppercase">Users (12 months)</div>
                        <div class="h4 fw-bold mb-0">{{userscurrentmonth}}</div>
                        <div class="small text-muted">New users this month</div>
                    </div>
                    <div class="text-primary"><i class="fa fa-users"></i></div>
                </div>

                <svg viewBox="0 0 320 96" width="100%" height="86" aria-label="Users trend curve" role="img">
                    <path d="{{userschartareapath}}" fill="rgba(15,108,191,0.14)"></path>
                    <path d="{{userschartlinepath}}" fill="none" stroke="#0f6cbf" stroke-width="3" stroke-linecap="round"></path>
                </svg>

                <div class="small text-muted">Peak: {{usersmax}}</div>
            </div>
        </div>
    </div>

    <div class="col-12 col-lg-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <div class="text-muted small text-uppercase">Revenue (12 months)</div>
                        <div class="h4 fw-bold mb-0">${{revenuecurrentmonth}}</div>
                        <div class="small text-muted">Revenue this month</div>
                    </div>
                    <div class="text-success"><i class="fa fa-line-chart"></i></div>
                </div>

                <svg viewBox="0 0 320 96" width="100%" height="86" aria-label="Revenue trend curve" role="img">
                    <path d="{{revenuechartareapath}}" fill="rgba(32,140,99,0.15)"></path>
                    <path d="{{revenuechartlinepath}}" fill="none" stroke="#208c63" stroke-width="3" stroke-linecap="round"></path>
                </svg>

                <div class="small text-muted">Peak: ${{revenuemax}}</div>
            </div>
        </div>
    </div>

</div>